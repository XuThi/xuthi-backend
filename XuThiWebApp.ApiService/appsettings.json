{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://www.yourdomain1.com",
      "https://www.yourdomain2.com"
    ]
  },
  "Jwt": {
    "Key": "yourjwtkeysecret",
    "Issuer": "yourdomain.com",
    "Audience": "yourdomain.com"
  },
  "Email": {
